  "keyFeatures": [
    "AST-based bytecode generation for ~64% faster serialization",
    "Universal API for JSON, YAML, TOML, MsgPack, CBOR, BSON, and Pickle",
    "Built-in validators (Range, Length, Match, OneOf)",
    "Field customization with rename, skip, defaults, and custom serializers",
    "JSON Schema generation for documentation and validation",
    "Native support for numpy, pandas, and polars",
    "Streaming serialization for large datasets",
    "Secure-by-default SafeUnpickler implementation",
    "Detailed error reporting with path tracking"
  ],
  "publicApiSurface": [
    "@lodum decorator",
    "field() function",
    "asdict() and fromdict() functions",
    "schema() function",
    "json.dumps() / json.loads() / json.dump_stream() / json.load_stream()",
    "yaml.dumps() / yaml.loads()",
    "pickle.dumps() / pickle.loads()",
    "toml.dumps() / toml.loads()",
    "msgpack.dumps() / msgpack.loads()",
    "cbor.dumps() / cbor.loads()",
    "bson.dumps() / bson.loads()",
    "validators.Range / Length / Match / OneOf",
    "Dumper and Loader protocols"
  ]
